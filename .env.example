# Railway обычно даёт DATABASE_URL для Postgres
DATABASE_URL=

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Настройки таблицы/полей (подставь реальные имена)
HEADLINES_TABLE=headlines
TEXT_COLUMN=text
CREATED_AT_COLUMN=created_at

# Сколько слов брать из text
WORDS_PER_ITEM=6

# Ограничение на количество строк в сообщении
MAX_ITEMS=50
